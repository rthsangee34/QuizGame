# Backend Server Configuration
PORT=5000

# Firebase Admin SDK Configuration (Choose ONE of the authentication methods below)

# Method 1: Google Application Credentials (Path to service account JSON file)
# GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json

# Method 2: Raw Firebase Service Account JSON (Alternative for direct env variable injection)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type": "service_account", "project_id": "your-project-id", ...}

# Optional settings
# FIREBASE_PROJECT_ID=your-project-id
